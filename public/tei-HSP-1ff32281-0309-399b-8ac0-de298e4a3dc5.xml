                <msContents>
                    <msItem xml:id="obj_90682841_INI">
                        <note type="text">
                            <locus>154r</locus>

                            <index indexName="initien">
                                <term facs="#HSK0516_b069" xml:lang="de">Di czehen gebot di got selber gab Moysi geschriben mit gotes vinger an czwayn stainen taveln, di scholtu merken an disem buoche</term>
                            </index>
</note>
                    </msItem>
                    <msItem xml:id="obj_90682844_INI">
                        <note type="text">
                            <locus>163v</locus>

                            <index indexName="initien">
                                <term facs="#HSK0516_b069" xml:lang="de">Also sprichet got czu dem menschen, der seinen heiligen leichnam wirdicleichen enpfehet und froloket in seiner sele: Duo enpfehst mich, so rainig ich dich fon suenden</term>
                            </index>
</note>
                    </msItem>
                    <msItem xml:id="obj_90682847_INI">
                        <note type="text">
                            <locus>173v</locus>

                            <index indexName="initien">
                                <term facs="#HSK0516_b069" xml:lang="de">grüßen, gegrüßt - Gegruest seistu Maria, in dem munde ain suzer name, in dem herczen ain teur schacze</term>
                            </index>
</note>
                    </msItem>
                    <msItem xml:id="obj_90682848_INI">
                        <note type="text">
                            <locus>180v</locus>

                            <index indexName="initien">
                                <term facs="#HSK0516_b069" xml:lang="la">Tres sunt penae ingratuitorum: Privatio gratiae spiritualis ... Et nota undecim nomina inferni: Primo vocatur in sacra scriptura lacus mortis, ain ze des todes</term>
                            </index>
</note>
                    </msItem>
                    <msItem xml:id="obj_90682849_INI">
                        <note type="text">
                            <locus>180v</locus>

                            <index indexName="initien">
                                <term facs="#HSK0516_b069" xml:lang="de">Tres sunt penae ingratuitorum: Privatio gratiae spiritualis ... Et nota undecim nomina inferni: Primo vocatur in sacra scriptura lacus mortis, ain ze des todes</term>
                            </index>
</note>
                    </msItem>
                    <msItem xml:id="obj_90682851_INI">
                        <note type="text">
                            <locus>182v</locus>

                            <index indexName="initien">
                                <term facs="#HSK0516_b069" xml:lang="la">Elatio dicitur uebermuot, arrogantia - geuden vel gueften</term>
                            </index>
</note>
                    </msItem>
                    <msItem xml:id="obj_90682852_INI">
                        <note type="text">
                            <locus>182v</locus>

                            <index indexName="initien">
                                <term facs="#HSK0516_b069" xml:lang="de">Elatio dicitur uebermuot, arrogantia - geuden vel gueften</term>
                            </index>
</note>
                    </msItem>
                    <msItem xml:id="obj_90682854_INI">
                        <note type="text">
                            <locus>183v</locus>

                            <index indexName="initien">
                                <term facs="#HSK0516_b069" xml:lang="la">Araxanus - habr; franeus - iessen</term>
                            </index>
</note>
                    </msItem>
                    <msItem xml:id="obj_90682855_INI">
                        <note type="text">
                            <locus>183v</locus>

                            <index indexName="initien">
                                <term facs="#HSK0516_b069" xml:lang="de">Araxanus - habr; franeus - iessen</term>
                            </index>
</note>
                    </msItem>
                    <msItem xml:id="obj_90682857_INI">
                        <note type="text">
                            <locus>204r</locus>

                            <index indexName="initien">
                                <term facs="#HSK0516_b069" xml:lang="de">Der heilig vater sant Bernhard ist geleichet dreien achpern fuersten von der alten e. Der erste ist Moyses</term>
                            </index>
</note>
                    </msItem>
                    <msItem xml:id="obj_90682860_INI">
                        <note type="text">
                            <locus>222v</locus>

                            <index indexName="initien">
                                <term facs="#HSK0516_b069" xml:lang="de">Dise hohczeit unser vrawen hat drey merkleich namen: Des ersten ist si genant der tage des slaffes, darumme das gottes muoter an disem tage di valsche werlt ueberwunde hat</term>
                            </index>
</note>
                    </msItem>
                    <msItem xml:id="obj_90682862_INI">
                        <note type="text">
                            <locus>225r</locus>

                            <index indexName="initien">
                                <term facs="#HSK0516_b069" xml:lang="de">Dise predig mant uns, das wir den heyligen gaist enphahen schuellen in fierlay weise: Des ersten mit des cristenleichen frides gemaynunge</term>
                            </index>
</note>
                    </msItem>
                    <msItem xml:id="obj_90682864_INI">
                        <note type="text">
                            <locus>227v</locus>

                            <index indexName="initien">
                                <term facs="#HSK0516_b069" xml:lang="de">Sant Peter und send Paul seint mit ainadern [!] gewonet als tzwen bruder an siben sachen. Des ersten an der cristenhait stiftunge</term>
                            </index>
</note>
                    </msItem>
                    <msItem xml:id="obj_90682866_INI">
                        <note type="text">
                            <locus>231r</locus>

                            <index indexName="initien">
                                <term facs="#HSK0516_b069" xml:lang="de">An der gaistleichen freude sein sechs hande pilde, dar an sich sant Margareth gefreut hat und uns das pilde der freuden gelassen hat</term>
                            </index>
</note>
                    </msItem>
                    <msItem xml:id="obj_90682867_INI">
                        <note type="text">
                            <locus>231r</locus>

                            <index indexName="initien">
                                <term facs="#HSK0516_b069" xml:lang="de">Der gotes suon ist in dise werlt quomen in ierlay weise: Sein erste chuonfte ist wunderleich, di leit an unser menschait vorainunge</term>
                            </index>
</note>
                    </msItem>
                    <msItem xml:id="obj_90682868_INI">
                        <note type="text">
                            <locus>231r</locus>

                            <index indexName="initien">
                                <term facs="#HSK0516_b069" xml:lang="de">Der grosße heilige prophete David spricht yn dem ersten psalme nach hundertin des salters</term>
                            </index>
</note>
                    </msItem>
                    <msItem xml:id="obj_90682871_INI">
                        <note type="text">
                            <locus>232r</locus>

                            <index indexName="initien">
                                <term facs="#HSK0516_b069" xml:lang="de">An disen worten seint czuo merken czway ding: Das ain ist der menschleichen crankhait derchennunge, das ander der gotleichen barmhertichait gemainunge</term>
                            </index>
</note>
                    </msItem>
                    <msItem xml:id="obj_90682874_INI">
                        <note type="text">
                            <locus>234r</locus>

                            <index indexName="initien">
                                <term facs="#HSK0516_b069" xml:lang="de">Unser hailant der gotes suon sicczet auf sechs stuelen uns czuo trost und czuo ainer fuerderunge. Des ersten siczzet er als ein mayster</term>
                            </index>
</note>
                    </msItem>
                    <msItem>
                        <note type="text">Inhalt Text</note>
                    </msItem>
